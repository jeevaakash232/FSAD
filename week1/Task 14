SELECT * FROM Student 
ORDER BY VTU_Number ASC;
SELECT * FROM Student 
ORDER BY VTU_Number DESC;
SELECT * FROM Student 
WHERE Department = 'CSE';
SELECT 
    s.VTU_Number, 
    s.Name AS Student_Name, 
    c.Course_Name, 
    c.Faculty_Id,
    c.Faculty_Email
FROM Student s
INNER JOIN Course c ON s.VTU_Number = c.Student_ID;
SELECT 
    s.VTU_Number, 
    s.Name, 
    c.Course_Name
FROM Student s
LEFT JOIN Course c ON s.VTU_Number = c.Student_ID;
SELECT 
    s.Name, 
    c.Course_Code, 
    c.Course_Name
FROM Student s
RIGHT JOIN Course c ON s.VTU_Number = c.Student_ID;
SELECT s.Name, c.Course_Name FROM Student s
LEFT JOIN Course c ON s.VTU_Number = c.Student_ID
UNION
SELECT s.Name, c.Course_Name FROM Student s
RIGHT JOIN Course c ON s.VTU_Number = c.Student_ID;
SELECT s.Name, c.Course_Name
FROM Student s
CROSS JOIN Course c;
