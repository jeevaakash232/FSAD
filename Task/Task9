  <div th:if="${emp != null}">
    <p><b>ID:</b> <span th:text="${emp.id}"></span></p>
    <p><b>Name:</b> <span th:text="${emp.name}"></span></p>
    <p><b>Department:</b> <span th:text="${emp.dept}"></span></p>
