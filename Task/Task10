<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
  <title>Student Form</title>
  <meta charset="UTF-8"/>
</head>
<body>
<h2 th:text="${student.id == null ? 'Create Student' : 'Edit Student'}"></h2>
